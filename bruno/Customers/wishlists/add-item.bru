meta {
  name: Add Item to Wishlist
  type: http
  seq: 12
}

post {
  url: {{BASE_URL}}/api/v1/wishlist/items
  body: json
}

headers {
  Authorization: Bearer {{auth_token}}
}

body:json {
  {
    "variant_id": 1
  }
}

assert {
  res.status: eq 201
}

script:post-response {
  bru.setVar("wishlist_variant_id", res.body.data.variant_id);
}
