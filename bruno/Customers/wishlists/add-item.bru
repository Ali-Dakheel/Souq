meta {
  name: Add Item to Wishlist
  type: http
  seq: 12
}

post {
  url: {{BASE_URL}}/api/v1/wishlist/items
  body: json
}

headers {
  Authorization: Bearer {{auth_token}}
}

body:json {
  {
    "variant_id": 1
  }
}

assert {
  res.status: eq 201
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("wishlist_variant_id", req.body.variant_id);
  }
}
