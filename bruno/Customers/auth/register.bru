meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{BASE_URL}}/api/v1/auth/register
  body: json
}

body:json {
  {
    "name": "Test Customer",
    "email": "test@example.com",
    "password": "password",
    "password_confirmation": "password"
  }
}

assert {
  res.status: eq 201
  res.body.data.user.email: eq "test@example.com"
}
