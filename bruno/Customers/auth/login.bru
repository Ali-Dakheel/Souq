meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{BASE_URL}}/api/v1/auth/login
  body: json
}

body:json {
  {
    "email": "test@example.com",
    "password": "password"
  }
}

assert {
  res.status: eq 200
  res.body.token: isNotEmpty
  res.body.data.email: isNotEmpty
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("auth_token", res.body.token);
  }
}
