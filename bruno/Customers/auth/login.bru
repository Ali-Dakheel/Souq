meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{BASE_URL}}/api/v1/auth/login
  body: json
}

body:json {
  {
    "email": "test@example.com",
    "password": "Password@123"
  }
}

assert {
  res.status: eq 200
  res.body.data.token: isNotEmpty
  res.body.data.user.email: eq "test@example.com"
}

script:post-response {
  bru.setVar("auth_token", res.body.data.token);
}
