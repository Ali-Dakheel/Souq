# ─────────────────────────────────────────────
# Tap Payments
# Get from: dashboard.tap.company
# ─────────────────────────────────────────────
TAP_SECRET_KEY=sk_test_xxxxxxxxxxxx
TAP_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
TAP_WEBHOOK_SECRET=your_webhook_secret_here

# ─────────────────────────────────────────────
# Laravel
# Generate with: php artisan key:generate --show
# ─────────────────────────────────────────────
APP_KEY=base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# Email (Resend)
# Get from: resend.com/api-keys
# ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx

# ─────────────────────────────────────────────
# Meilisearch (uncomment when catalog > 200 products)
# ─────────────────────────────────────────────
# MEILISEARCH_KEY=your_master_key_here

# ─────────────────────────────────────────────
# Sentry (error monitoring — add when going to production)
# ─────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_DSN=https://xxx@sentry.io/xxx
